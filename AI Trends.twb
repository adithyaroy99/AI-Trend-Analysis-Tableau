      <column caption='Adoption 2023 (Country)' datatype='real' name='[Calculation_1705175449542045696]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [Country] :&#13;&#10;    AVG( IF [Year] = 2023 THEN [Calculation_1885319434250379265] END )&#13;&#10;}' />
