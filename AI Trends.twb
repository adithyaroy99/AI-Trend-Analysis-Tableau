      <column caption='Keep Country (TopBottom)' datatype='boolean' name='[Calculation_1885319434265198597]' role='measure' type='nominal'>
        <calculation class='tableau' formula='[Calculation_1885319434264682500] &lt;= [Parameters].[Parameter 1]'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Sort Value (TopBottom)' datatype='real' name='[Calculation_1885319434266193926]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Parameters].[Rank Parameter] = &quot;Top&quot; THEN MAX([Calculation_1885319434260389890])&#13;&#10;ELSE -MAX([Calculation_1885319434260389890])&#13;&#10;END' />
      </column>
      <column caption='Market Segment (2023)' datatype='string' name='[Calculation_1885319434353016839]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF AVG([Calculation_1885319434250379265]) &gt;= [Parameters].[AI Adoption Rate (0-1) Parameter]&#13;&#10;AND AVG([AI_Readiness_Score]) &gt;= [Parameters].[Country Label Parameter]&#13;&#10;THEN &quot;Scale Now&quot;&#13;&#10;&#13;&#10;ELSEIF AVG([Calculation_1885319434250379265]) &lt; [Parameters].[AI Adoption Rate (0-1) Parameter]&#13;&#10;AND AVG([AI_Readiness_Score]) &gt;= [Parameters].[Country Label Parameter]&#13;&#10;THEN &quot;Build Demand&quot;&#13;&#10;&#13;&#10;ELSEIF AVG([Calculation_1885319434250379265]) &gt;= [Parameters].[AI Adoption Rate (0-1) Parameter]&#13;&#10;AND AVG([AI_Readiness_Score]) &lt; [Parameters].[Country Label Parameter]&#13;&#10;THEN &quot;De-risk First&quot;&#13;&#10;&#13;&#10;ELSE &quot;Monitor&quot;&#13;&#10;END' />
      </column>
      <column caption='Label - Scale Now' datatype='string' name='[Calculation_3325626890424201216]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_1885319434353016839] = &quot;Scale Now&quot; THEN ATTR([Country])&#13;&#10;END' />
      </column>
      <column caption='Priority Score (2023)' datatype='real' name='[Calculation_3325626890432098308]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Parameters].[Adoption Threshold (copy)]  * [Calculation_1705175449543401481]&#13;&#10;+ [Parameters].[Top N Countries (copy)] * [Calculation_1705175449543581706]&#13;&#10;+ [Parameters].[Weight – Readiness (copy)] * [Calculation_1705175449543647243]' />
      </column>
      <column caption='Has all metrics (2023)' datatype='boolean' name='[Calculation_3325626890441482257]' role='measure' type='nominal'>
        <calculation class='tableau' formula='NOT ISNULL(AVG([Calculation_1885319434250379265]))&#13;&#10;AND NOT ISNULL(AVG([AI_Readiness_Score]))&#13;&#10;AND NOT ISNULL(SUM([AI_VC_Investment]))' />
      </column>
