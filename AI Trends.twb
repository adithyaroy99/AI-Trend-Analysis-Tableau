      </column>
      <column caption='Max Investment 2023' datatype='real' name='[Calculation_1705175449543340040]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED : MAX([Calculation_1705175449542451202]) }' />
      </column>
      <column caption='Adoption (norm 2023)' datatype='real' name='[Calculation_1705175449543401481]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Calculation_1705175449543053316] = [Calculation_1705175449542979587] THEN 0&#13;&#10;ELSE ([Calculation_1705175449542045696] - [Calculation_1705175449542979587]) / ([Calculation_1705175449543053316] - [Calculation_1705175449542979587])&#13;&#10;END' />
      </column>
      <column caption='Readiness (norm 2023)' datatype='real' name='[Calculation_1705175449543581706]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Calculation_1705175449543204870] = [Calculation_1705175449543159813] THEN 0&#13;&#10;ELSE ([Calculation_1705175449542397953] - [Calculation_1705175449543159813]) / ([Calculation_1705175449543204870] - [Calculation_1705175449543159813])&#13;&#10;END' />
      </column>
      <column caption='Investment (norm 2023)' datatype='real' name='[Calculation_1705175449543647243]' role='measure' type='quantitative'>
