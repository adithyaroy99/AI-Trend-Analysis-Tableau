      <column caption='Label - High priority' datatype='string' name='[Calculation_1705175449560440846]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF AVG([Calculation_3325626890432098308]) &gt;= 0.70 THEN ATTR([Country]) END' />
      </column>
      <column caption='Latest Adoption Rate' datatype='real' name='[Calculation_1885319434217795584]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [Country] :&#13;&#10;    MAX( IF [Year] = { FIXED : MAX([Year]) } THEN [AI_Adoption_Rate] END )&#13;&#10;}' />
      </column>
      <column caption='AI Adoption Rate (0-1)' datatype='real' name='[Calculation_1885319434250379265]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[AI_Adoption_Rate] / 100' />
      </column>
      <column caption='Latest Adoption %' datatype='real' name='[Calculation_1885319434260389890]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [Country] :&#13;&#10;    MAX(&#13;&#10;        IF [Year] = { FIXED : MAX([Year]) }&#13;&#10;        THEN [Calculation_1885319434250379265]&#13;&#10;        END&#13;&#10;    )&#13;&#10;}' />
      </column>
      <column caption='Rank (TopBottom)' datatype='integer' name='[Calculation_1885319434264682500]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Parameters].[Rank Parameter] = &quot;Top&quot; THEN&#13;&#10;    RANK_DENSE(MAX([Calculation_1885319434260389890]))&#13;&#10;ELSE&#13;&#10;    RANK_DENSE(-MAX([Calculation_1885319434260389890]))&#13;&#10;END'>
