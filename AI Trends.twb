      <column caption='Readiness 2023 (Country)' datatype='real' name='[Calculation_1705175449542397953]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [Country] :&#13;&#10;    AVG([AI_Readiness_Score])&#13;&#10;}' />
      </column>
      <column caption='Investment 2023 (Country)' datatype='real' name='[Calculation_1705175449542451202]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [Country] :&#13;&#10;    SUM( IF [Year (Sheet11)] = 2023 THEN [AI_VC_Investment] END )&#13;&#10;}' />
      </column>
      <column caption='Min Adoption 2023' datatype='real' name='[Calculation_1705175449542979587]' role='measure' type='quantitative'>
