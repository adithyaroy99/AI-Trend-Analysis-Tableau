      </column>
      <column caption='Max Adoption 2023' datatype='real' name='[Calculation_1705175449543053316]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED : MAX([Calculation_1705175449542045696]) }' />
      </column>
      <column caption='Min Readiness 2023' datatype='real' name='[Calculation_1705175449543159813]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED : MIN([Calculation_1705175449542397953]) }' />
      </column>
      <column caption='Max Readiness 2023' datatype='real' name='[Calculation_1705175449543204870]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED : MAX([Calculation_1705175449542397953]) }' />
      </column>
      <column caption='Min Investment 2023' datatype='real' name='[Calculation_1705175449543245831]' role='measure' type='quantitative'>
